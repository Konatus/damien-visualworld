{
  "apps": [
    {
      "name": "visualworld-api",
      "script": "npm",
      "args": "start",
      "cwd": "./api",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "env": {
        "NODE_ENV": "production",
        "PORT": 8080
      },
      "error_file": "/var/log/visualworld-api-error.log",
      "out_file": "/var/log/visualworld-api-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "max_memory_restart": "500M"
    },
    {
      "name": "visualworld-front",
      "script": "npm",
      "args": "run serve",
      "cwd": "./front",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "env": {
        "NODE_ENV": "development",
        "NODE_OPTIONS": "--openssl-legacy-provider",
        "PORT": 3333
      },
      "error_file": "/var/log/visualworld-front-error.log",
      "out_file": "/var/log/visualworld-front-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "max_memory_restart": "1G"
    }
  ]
}
