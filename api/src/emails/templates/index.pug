doctype html
html
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel='stylesheet', href='/css/styles.css')
    body
        table(width='100%' border='0' align='center' cellspacing='0' cellpadding='5' class='email-content')
            tbody
                tr
                    td
                        table(width='100%' cellspacing='0' cellpadding='20')
                            tbody
                                tr
                                td(align='center')
                                    p=`${$t.__("email.template.hello", {username}).trim()},`
                                    block content
                            tfoot
                                tr
                                td(align='center')
                                    p(style='margin: 0;')= $t.__("email.template.team")
                                    a(href=`mailto:${support}`)=support
                                    p
                                    a(href='https://visual.world')
                                        img(src="/img/vw-full-rgb.png", alt="", srcset="" width=150)